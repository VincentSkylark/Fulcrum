{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash",
      "Glob",
      "Grep",
      "Web_fetch",
      "Task",
      "Skill",
      "mcp__*",
      "mcp__zread__read_file",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id",
      "WebSearch",
      "mcp__web-reader__webReader",
      "mcp__roslyn__get_diagnostics"
    ],
    "deny": []
  },
  "enabledMcpjsonServers": [
    "roslyn",
    "context7",
    "playwright"
  ],
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"(New-Object Media.SoundPlayer 'C:\\\\Windows\\\\Media\\\\Windows Exclamation.wav').PlaySync()\""
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"(New-Object Media.SoundPlayer 'C:\\\\Windows\\\\Media\\\\Windows Notify.wav').PlaySync()\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"(New-Object Media.SoundPlayer 'C:\\\\Windows\\\\Media\\\\Windows Ding.wav').PlaySync()\""
          }
        ]
      }
    ]
  }
}
